<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_shield"
                app:tint="#1A6B3C"
                android:contentDescription="logo" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="DGAP SÉNÉGAL"
                android:textColor="#1A6B3C"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_account_circle"
                android:background="@drawable/circle_bg"
                android:contentDescription="profil" />
        </LinearLayout>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INTERFACE DE CONTRÔLE"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:layout_marginBottom="4dp"/>

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tableau de Bord -\nVérification"
            android:textColor="#1A1A1A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginBottom="24dp"/>

        <!-- CARD MEMBRE DE RÉFÉRENCE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEMBRE DE RÉFÉRENCE"
                    android:textColor="#888888"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp"/>

                <!-- DROPDOWN -->
                <Spinner
                    android:id="@+id/spinner_doigt"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_bg"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <!-- SENSOR STATUS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_fingerprint"
                        android:background="@drawable/sensor_icon_bg"
                        android:padding="8dp"
                        android:contentDescription="capteur"
                        app:tint="#1A6B3C"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Capteur Optique Prêt"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Assurez-vous que la\nsurface du capteur est propre."
                            android:textColor="#666666"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARD INSTRUCTIONS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A6B3C">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Instructions de Numérisation"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assurez-vous que la surface du capteur MobiBo est propre. Placez le doigt sélectionné fermement au centre du prisme et maintenez la pression jusqu'au signal sonore."
                    android:textColor="#CCFFD6"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="20dp"/>

                <!-- BOUTON SCAN -->
                <Button
                    android:id="@+id/btn_lancer_scan"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="📷  LANCER LE SCAN"
                    android:textColor="#1A6B3C"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:background="@drawable/btn_white_rounded"
                    android:elevation="0dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>