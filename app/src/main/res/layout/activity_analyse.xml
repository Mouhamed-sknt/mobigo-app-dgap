<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAF8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/dgap"
                android:contentDescription="logo" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="DGAP SÉNÉGAL"
                android:textColor="#1A6B3C"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_account_circle"
                android:background="@drawable/circle_bg"
                android:padding="4dp"
                android:contentDescription="profil" />
        </LinearLayout>

        <!-- Bouton Retour -->

        <!-- Titre -->
        <Button
            android:id="@+id/btn_retour"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/btn_outline_rounded"
            android:text="← Retour au Tableau de Bord"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyse de l'Empreinte"
            android:textColor="#1A1A1A"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOVEREIGN SENTINEL PROTOCOL V2.4"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:layout_marginBottom="24dp"/>

        <!-- Banner Status -->
        <LinearLayout
            android:id="@+id/banner_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/banner_green_bg"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_info"
                app:tint="#1A6B3C"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/txt_status_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Veuillez poser votre doigt sur le capteur"
                android:textColor="#1A6B3C"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Zone Empreinte avec animation -->
        <RelativeLayout
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <!-- Cercles de fond -->
            <View
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:background="@drawable/circle_outer_green"
                android:alpha="0.25"
                android:layout_centerInParent="true"/>

            <View
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:background="@drawable/circle_outer_green"
                android:alpha="0.12"
                android:layout_centerInParent="true"/>

            <!-- Cercle intérieur -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:background="@drawable/circle_inner_white"
                android:layout_centerInParent="true"/>

            <!-- Icône Empreinte -->
            <ImageView
                android:id="@+id/img_fingerprint"
                android:layout_width="110dp"
                android:layout_height="110dp"
                app:tint="#1A6B3C"
                android:src="@drawable/ic_fingerprint"
                android:layout_centerInParent="true"
                android:contentDescription="empreinte"/>


            <!-- Ligne de scan -->
            <View
                android:id="@+id/scan_line"
                android:layout_width="200dp"
                android:layout_height="3dp"
                android:background="#1A6B3C"
                android:alpha="0.9"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- Statut Scan -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/badge_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="8dp">

            <View
                android:id="@+id/dot_status"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/dot_green"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/txt_scan_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan en cours..."
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txt_scan_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Analyse des minuties en cours..."
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginBottom="32dp"/>

        <!-- Qualité et Type -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="32dp">

            <!-- Qualité -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QUALITÉ"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/txt_qualite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="94%"
                        android:textColor="#1A6B3C"
                        android:textSize="32sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Type -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="96dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TYPE"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/txt_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Index D"
                        android:textColor="#1A1A1A"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>