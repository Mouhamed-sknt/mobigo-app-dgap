<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAF8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/dgap"
                android:contentDescription="logo" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="DGAP SÉNÉGAL"
                android:textColor="#1A6B3C"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_account_circle"
                android:background="@drawable/circle_bg"
                android:padding="4dp"
                android:contentDescription="profil" />
        </LinearLayout>

        <!-- SOUS-TITRE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INTERFACE DE CONTRÔLE"
            android:textColor="#888888"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp"/>

        <!-- TITRE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tableau de Bord -"
            android:textColor="#1A1A1A"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vérification"
            android:textColor="#1A1A1A"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <!-- CARD MEMBRE DE RÉFÉRENCE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEMBRE DE RÉFÉRENCE"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp"/>

                <!-- Spinner Doigt -->
                <Spinner
                    android:id="@+id/spinner_doigt"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/spinner_bg"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="20dp"/>

                <!-- Capteur Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/sensor_icon_bg"
                        android:gravity="center"
                        android:layout_marginEnd="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_fingerprint"
                            app:tint="#1A6B3C"
                            android:contentDescription="capteur"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Capteur Optique Prêt"
                            android:textColor="#1A1A1A"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Assurez-vous que la surface du capteur est propre."
                            android:textColor="#666666"
                            android:textSize="13sp"
                            android:lineSpacingMultiplier="1.3"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CARD INSTRUCTIONS + BOUTON -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#1A6B3C">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Instructions de Numérisation"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assurez-vous que la surface du capteur MobiGo est propre. Placez le doigt sélectionné fermement au centre du prisme et maintenez la pression jusqu’au signal sonore."
                    android:textColor="#CCFFD6"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.45"
                    android:layout_marginBottom="32dp"/>

                <!-- Bouton LANCER LE SCAN -->
                <Button
                    android:id="@+id/btnLaunchScan"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    style="@style/AppTheme"
                    android:text="LANCER LE SCAN"
                    android:textColor="@color/success_green"
                    android:backgroundTint="?attr/colorOnPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:drawablePadding="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>